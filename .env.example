# ── OpenAQ ──────────────────────────────────────────────
# Free API key from https://openaq.org/register
OPENAQ_API_KEY=your_openaq_api_key_here

# Cities to monitor (comma-separated — use OpenAQ city names)
OPENAQ_CITIES=Los Angeles,New York,Chicago,Houston,Phoenix

# ── PostgreSQL (local — installed via Homebrew) ──────────
# On Mac with Homebrew Postgres, no password is needed by default.
# Username = your Mac username (run: whoami in terminal)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=airquality
POSTGRES_USER=your_mac_username_here
POSTGRES_PASSWORD=

# ── dbt ─────────────────────────────────────────────────
DBT_PROFILES_DIR=./dbt
